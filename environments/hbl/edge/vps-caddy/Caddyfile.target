# Target public edge state for the NOF VPS Caddy environment.
#
# This file is intentionally secret-free. It is not applied automatically.
# Before applying, compare it with /etc/caddy/Caddyfile on the VPS and keep a
# timestamped backup.

{
	log default {
		output file /var/log/caddy/caddy.log {
			roll_size 10MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format filter {
			wrap json
			fields {
				request>headers>Authorization delete
				request>headers>Cookie delete
				request>headers>X-Api-Key delete
				request>headers>X-Telegram-Bot-Api-Secret-Token delete
				resp_headers>Set-Cookie delete
			}
		}
	}
}

(forgath_access_log) {
	log {
		output file /var/log/caddy/forgath-access.log {
			roll_size 20MiB
			roll_keep 14
			roll_keep_for 720h
		}
		format filter {
			wrap json
			fields {
				request>headers>Authorization delete
				request>headers>Cookie delete
				request>headers>X-Api-Key delete
				request>headers>X-Telegram-Bot-Api-Secret-Token delete
				resp_headers>Set-Cookie delete
			}
		}
	}
}

forgath.ru, www.forgath.ru {
	import forgath_access_log
	encode zstd gzip
	reverse_proxy 127.0.0.1:18080 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

task-tracker.forgath.ru {
	import forgath_access_log
	encode zstd gzip
	reverse_proxy 127.0.0.1:18080 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

habit-tracker.forgath.ru {
	import forgath_access_log
	encode zstd gzip
	reverse_proxy 127.0.0.1:18080 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
